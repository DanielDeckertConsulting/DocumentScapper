APP_NAME=DocumentScrapper
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=documentscapper
DB_USERNAME=documentscapper
DB_PASSWORD=secret

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SAME_SITE=lax

CACHE_STORE=redis
CACHE_PREFIX=documentscapper

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Storage (lokal für Dev, S3-kompatibel für Prod)
DOCUMENT_STORAGE_DISK=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-central-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# OpenAI
OPENAI_API_KEY=your_key_here
OPENAI_MODEL_EXTRACTION=gpt-4o-mini
OPENAI_MODEL_CHAT=gpt-4o-mini

# Sanctum (SPA Frontend URL)
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000

FRONTEND_URL=http://localhost:5173
